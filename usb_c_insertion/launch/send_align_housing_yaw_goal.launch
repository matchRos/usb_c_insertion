<launch>
  <arg name="image_topic" default="/zedm/zed_node/left/image_rect_color" />
  <arg name="cloud_topic" default="/zedm/zed_node/point_cloud/cloud_registered" />

  <node pkg="usb_c_insertion"
        type="send_align_housing_yaw_goal.py"
        name="usb_c_insertion_align_housing_yaw_goal_client"
        output="screen">
    <rosparam command="load" file="$(find usb_c_insertion)/config/insertion_params.yaml" />
    <param name="align_housing_yaw/image_topic" value="$(arg image_topic)" />
    <param name="align_housing_yaw/cloud_topic" value="$(arg cloud_topic)" />
  </node>
</launch>
